generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// === Better Auth ===

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String    @default("user")
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  traces        Trace[]
  bateaux       Bateau[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// === Domaine ===

model Bateau {
  id        String   @id @default(cuid())
  nom       String
  type      String?
  classe    String?
  longueur  Float?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Trace {
  id              String       @id @default(cuid())
  name            String
  filename        String
  format          String
  source          String       @default("unknown")
  createdAt       DateTime     @default(now())
  startedAt       DateTime?
  distanceNm      Float?
  durationSeconds Int?
  avgSpeedKn      Float?
  maxSpeedKn      Float?
  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  points          TrackPoint[]

  @@index([userId])
}

model TrackPoint {
  id         String   @id @default(cuid())
  traceId    String
  trace      Trace    @relation(fields: [traceId], references: [id], onDelete: Cascade)
  lat        Float
  lon        Float
  timestamp  DateTime?
  speedKn    Float?
  headingDeg Float?
  elevationM Float?
  pointIndex Int

  @@index([traceId])
}
